# If using OLLAMA 
OLLAMA_API_KEY="ollama"
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_AI_MODEL="deepseek-r1:1.5b"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# If using GEMINI update the variable name in server/src/gemini.js
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
GEMINI_API_KEY="AI...your_gemini_api_key"
GEMINI_AI_MODEL="gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# Auth
JWT_SECRET="your_JWT_secret"

# Server
PORT=3001

# Postgres
DATABASE_URL="postgresql://<username>:<password>@localhost:5432/nextwatch?schema=public"

# Mail Service
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="user@gmail.com"
SMTP_PASS="your_application_password"
SMTP_FROM="Nextwatch <no-reply@example.com>"